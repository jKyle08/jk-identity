{
  "name": "jk-identity",
  "version": "0.3.0",
  "private": true,
  "description": "A reusable, enterprise-grade Identity & Authentication package for NestJS applications using Clean Architecture and Hexagonal Architecture (Ports & Adapters).",
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "build": "npm run build --workspace=@jk/identity && npm run build --workspace=@jk/identity-memory && npm run build --workspace=@jk/identity-playground",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspace=@jk/identity",
    "test:unit": "npm run test:unit --workspace=@jk/identity",
    "test:integration": "npm run test:integration --workspace=@jk/identity",
    "test:e2e": "npm run test:e2e --workspace=@jk/identity",
    "test:cov": "npm run test:cov --workspace=@jk/identity",
    "playground": "npm run start:dev --workspace=@jk/identity-playground",
    "format": "prettier --write \"**/*.{ts,json,md}\""
  },
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jKyle08/jk-identity.git"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.21.0"
  }
}
