# Copy to .env for playground / local development
# Used by apps/playground — see apps/playground/.env.example for full options

PORT=3000
JWT_SECRET=change-me-use-long-random-string
JWT_REFRESH_SECRET=change-me-use-different-long-random-string
ACCESS_TOKEN_EXPIRATION=15m
REFRESH_TOKEN_EXPIRATION=30d

# Uncomment to enable Google OAuth
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

SEND_LOGIN_NOTIFICATION=false
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
